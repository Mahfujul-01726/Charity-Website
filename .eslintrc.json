{
    "root": true,
    "env": {
        "browser": true,
        "es2021": true,
        "node": true
    },
    "extends": [
        "eslint:recommended"
    ],
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module",
        "ecmaFeatures": {
            "jsx": true
        }
    },
    "rules": {
        "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
        "no-console": "off"
    },
    "overrides": [
        {
            "files": ["client/src/**/*.jsx", "client/src/**/*.js"],
            "env": {
                "browser": true
            }
        },
        {
            "files": ["server/src/**/*.js"],
            "env": {
                "node": true
            }
        }
    ]
}
